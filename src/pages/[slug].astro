---
import Layout from '@/layouts/Layout.astro';
import { getIcon, favicon } from '@/lib/icons';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
	const clubs = await getCollection('clubs');
	return clubs.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { description, theme_color_light, theme_color_dark, links, location, name } = entry.data;

function linkDisplay(label: string, url: string) {
	const displayMap: Record<string, (_: string) => string> = {
		Website: (url) => new URL(url).hostname,
		Instagram: (url) => `@${new URL(url).pathname.split('/').filter(Boolean)[0]}`,
		X: (url) => `@${new URL(url).pathname.split('/').filter(Boolean)[0]}`,
		LinkedIn: (url) => `${new URL(url).pathname.split('/').filter(Boolean)[1]}`,
		GitHub: (url) => `@${new URL(url).pathname.split('/').filter(Boolean)[0]}`,
		WhatsApp: () => 'Join',
		Discord: () => 'Join',
		Telegram: () => 'Join',
	};
	return displayMap[label]?.(url) ?? "Link";
}

const icon = getIcon(entry.id)
---

<Layout title={name}>
	<main class="club-page" style={`--accent-light: ${theme_color_light || 'var(--text)'}; --accent-dark: ${theme_color_dark || theme_color_light || 'var(--text)'}`}>
		<a href="/" class="back-button">← All Clubs</a>
		<article>
			<header style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
				<div style="display: flex; gap: 1rem; align-items: center">
					<Image
						src={icon}
						class="club-favicon"
						alt={name + " icon"}
						format="png"
						style={"height: 67px; width: 67px;" + (icon === favicon ? "image-rendering: pixelated;" : "")}
					/>
					<h1 style="margin: 0">{name}</h1>
				</div>
				<p style="margin: 0">{description}</p>
				{Object.values(links).some(e => e) && 
				<div class="links">
					{(Object.entries(links) as [[string, string]]).map(([label, url]) => (
						<div>
							<p class="label"><small>{label}</small></p>
							{/* display: block is needed otherwise there's a weird layout shift after first load */}
							<a style="display: block" href={url} target="_blank">{linkDisplay(label, url)}</a>
						</div>
					))}
				</div>}
				{location && (
					<div>
						<p class="label"><small>Location</small></p>
						<p class="location">{location}</p>
					</div>	
				)}
			</header>

			</div>
			<hr style="margin-bottom: 2rem;"/>
			<div class="content">
				<Content />
			</div>
		</article>
	</main>
</Layout>

<style>
	.club-page {
		--accent: light-dark(var(--accent-light), var(--accent-dark));
		max-width: 80ch;
		margin: 2rem auto;
		padding: 2rem;
		/* border: 1px solid var(--accent); */
		border-radius: 0.5rem;
		position: relative;
	}
	.back-button {
		display: inline-block;
		margin-bottom: 2rem;
		text-decoration: none;
		color: var(--text);
		opacity: 0.8;
	}
	.back-button:hover {
		opacity: 1;
	}
	header {
		margin-bottom: 1rem;
	}
	h1 {
		/* margin-bottom: 0.5rem; */
		color: var(--accent);
	}
	.location {
		margin: 0;
		opacity: 0.9;
	}
	.links {
		width: 100%;
		display: grid;
		grid-auto-flow: row;
		grid-template-columns: repeat(auto-fit, minmax(16ch, 1fr));
		gap: 1rem 3rem;
	}
	.label {
		margin: 0;
		line-height: 1;
		color: var(--secondary-light);
	}
	.links a:hover {
		border-bottom-color: var(--accent);
	}

</style>
